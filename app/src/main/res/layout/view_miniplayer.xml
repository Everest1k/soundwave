<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/miniplayer_bg"
    android:clickable="true"
    android:focusable="true">

    <ProgressBar
        android:id="@+id/mp_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:max="1000"
        android:progress="0"
        android:progressTint="@color/miniplayer_progress"
        android:progressBackgroundTint="@color/miniplayer_track"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/mp_cover"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:scaleType="centerCrop"
        android:background="@drawable/cover_placeholder"
        app:layout_constraintTop_toBottomOf="@id/mp_progress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/mp_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="@id/mp_cover"
        app:layout_constraintStart_toEndOf="@id/mp_cover"
        app:layout_constraintEnd_toStartOf="@id/mp_play" />

    <TextView
        android:id="@+id/mp_artist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/mp_title"
        app:layout_constraintStart_toEndOf="@id/mp_cover"
        app:layout_constraintEnd_toStartOf="@id/mp_play" />

    <ImageButton
        android:id="@+id/mp_play"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_play"
        android:contentDescription="@string/tab_home"
        app:layout_constraintTop_toTopOf="@id/mp_cover"
        app:layout_constraintBottom_toBottomOf="@id/mp_cover"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
